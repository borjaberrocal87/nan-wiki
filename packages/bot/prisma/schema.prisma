generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          BigInt    @id @map("id")
  username    String
  avatarUrl   String?   @map("avatar_url")
  discriminator String? @map("discriminator")
  joinedAt    DateTime @default(now()) @map("joined_at")
  isAdmin     Boolean   @default(false) @map("is_admin")
  links       Link[]
  conversations ChatConversation[]

  @@map("users")
}

model Channel {
  id          BigInt  @id @map("id")
  name        String
  guildId     BigInt  @map("guild_id")
  category    String?
  createdAt   DateTime? @map("created_at")
  links       Link[]

  @@map("channels")
}

model Source {
  id    String @id @map("id")
  name  String
  links Link[]

  @@map("sources")
}

model Link {
  id                  String    @id @default(uuid()) @map("id") @db.Uuid
  url                 String    @unique
  domain              String
  sourceId            String    @map("source_id")
  source              Source    @relation(fields: [sourceId], references: [id])
  authorId            BigInt?   @map("author_id")
  author              User?     @relation(fields: [authorId], references: [id])
  channelId           BigInt?   @map("channel_id")
  channel             Channel?  @relation(fields: [channelId], references: [id])
  discordMessageId    BigInt?   @map("discord_message_id")
  discordChannelName  String?   @map("discord_channel_name")
  postedAt            DateTime  @map("posted_at")
  llmStatus           String    @default("pending") @map("llm_status")
  title               String?
  description         String?   @db.Text
  sourceDetected      String?   @map("source_detected")
  linkTags            LinkTag[]
  // embedding column exists in DB (vector(1536)) but is managed by API via SQLAlchemy, not Prisma
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  @@index([sourceId])
  @@index([postedAt(order: Desc)])
  @@index([domain])

  @@map("links")
}

model Tag {
  id        String    @id @default(uuid()) @map("id") @db.Uuid
  name      String    @unique
  createdAt DateTime  @default(now()) @map("created_at")
  linkTags  LinkTag[]

  @@map("tags")
}

model LinkTag {
  linkId  String @map("link_id") @db.Uuid
  tagId   String @map("tag_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")
  link    Link   @relation(fields: [linkId], references: [id], onDelete: Cascade)
  tag     Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([linkId, tagId])
  @@index([tagId])

  @@map("link_tags")
}

model ChatConversation {
  id        String       @id @default(uuid()) @map("id") @db.Uuid
  userId    BigInt?      @map("user_id")
  user      User?        @relation(fields: [userId], references: [id])
  sessionId String       @map("session_id") @db.Uuid
  createdAt DateTime     @default(now()) @map("created_at")
  messages  ChatMessage[]

  @@map("chat_conversations")
}

model ChatMessage {
  id             String           @id @default(uuid()) @map("id") @db.Uuid
  conversationId String           @map("conversation_id") @db.Uuid
  conversation   ChatConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           String
  content        String
  createdAt      DateTime         @default(now()) @map("created_at")

  @@map("chat_messages")
}
