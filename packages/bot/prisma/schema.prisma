generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          BigInt    @id @map("id")
  username    String
  avatarUrl   String?   @map("avatar_url")
  discriminator String? @map("discriminator")
  joinedAt    DateTime @default(now()) @map("joined_at")
  isAdmin     Boolean   @default(false) @map("is_admin")
  links       Link[]
  conversations ChatConversation[]

  @@map("users")
}

model Channel {
  id          BigInt  @id @map("id")
  name        String
  guildId     BigInt  @map("guild_id")
  category    String?
  createdAt   DateTime? @map("created_at")
  links       Link[]

  @@map("channels")
}

model Link {
  id                  String    @id @default(uuid()) @map("id") @db.Uuid
  url                 String    @unique
  domain              String
  source              String
  rawContent          String?   @map("raw_content") @db.Text
  authorId            BigInt?   @map("author_id")
  author              User?     @relation(fields: [authorId], references: [id])
  channelId           BigInt?   @map("channel_id")
  channel             Channel?  @relation(fields: [channelId], references: [id])
  discordMessageId    BigInt?   @map("discord_message_id")
  discordChannelName  String?   @map("discord_channel_name")
  postedAt            DateTime  @map("posted_at")
  llmStatus           String    @default("pending") @map("llm_status")
  title               String?
  description         String?   @db.Text
  tags                String[]  @default([])
  sourceDetected      String?   @map("source_detected")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  @@index([source])
  @@index([postedAt(order: Desc)])
  @@index([domain])

  @@map("links")
}

model ChatConversation {
  id        String       @id @default(uuid()) @map("id") @db.Uuid
  userId    BigInt?      @map("user_id")
  user      User?        @relation(fields: [userId], references: [id])
  sessionId String       @map("session_id") @db.Uuid
  createdAt DateTime     @default(now()) @map("created_at")
  messages  ChatMessage[]

  @@map("chat_conversations")
}

model ChatMessage {
  id             String           @id @default(uuid()) @map("id") @db.Uuid
  conversationId String           @map("conversation_id") @db.Uuid
  conversation   ChatConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           String
  content        String
  createdAt      DateTime         @default(now()) @map("created_at")

  @@map("chat_messages")
}
