# ============================================
# LINK LIBRARY — Environment Variables
# ============================================
# Copy this file to .env and fill in the values.
# NEVER commit the .env file to git.
# ============================================

# -------------------------------------------
# DISCORD BOT
# -------------------------------------------
# Bot token from Discord Developer Portal
DISCORD_TOKEN=

# Server (guild) ID where the bot operates
DISCORD_GUILD_ID=

# -------------------------------------------
# API / BACKEND
# -------------------------------------------
# PostgreSQL connection string
DATABASE_URL=postgresql://user:pass@localhost:5432/linklibrary

# Redis connection string
REDIS_URL=redis://localhost:6379

# Secret for JWT session tokens (generate with: python -c "import secrets; print(secrets.token_hex(32))")
JWT_SECRET=

# Discord OAuth2 — app registered at https://discord.com/developers/applications
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=http://localhost:3000/api/auth/discord/callback

# OpenAI API key (for LLM descriptions, tags, and embeddings)
OPENAI_API_KEY=

# -------------------------------------------
# FRONTEND / WEB
# -------------------------------------------
# Base URL of the API (used by the Next.js frontend)
NEXT_PUBLIC_API_URL=http://localhost:8000

# OAuth callback URL (must match DISCORD_REDIRECT_URI)
NEXT_PUBLIC_OAUTH_CALLBACK_URL=http://localhost:3000/api/auth/discord/callback
