# ============================================
# LINK LIBRARY — Environment Variables
# ============================================
# Copy this file to .env and fill in the values.
# NEVER commit the .env file to git.
# ============================================

# -------------------------------------------
# DISCORD BOT
# -------------------------------------------
# Bot token from Discord Developer Portal
DISCORD_TOKEN=

# Server (guild) ID where the bot operates
DISCORD_GUILD_ID=

# Set to "true" to disable the bot's reply message in Discord after capturing a link
DISABLE_LINK_REPLY=false

# -------------------------------------------
# API / BACKEND
# -------------------------------------------
# PostgreSQL connection string
DATABASE_URL=postgresql://user:pass@localhost:5432/linklibrary

# Secret for JWT session tokens (generate with: python -c "import secrets; print(secrets.token_hex(32))")
JWT_SECRET=

# Discord OAuth2 — app registered at https://discord.com/developers/applications
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=http://localhost:3000/api/auth/discord/callback

# Custom LLM provider (OpenAI-compatible API)
LLM_BASE_URL=https://api.nan.builders/v1
LLM_MODEL=qwen3.6
EMBEDDING_MODEL=qwen3-embedding
LLM_API_KEY=

# Worker settings
WORKER_CONCURRENCY=3
WORKER_POLL_INTERVAL=5
MAX_RETRIES=5

# -------------------------------------------
# FRONTEND / WEB
# -------------------------------------------
# Base URL of the API (used by the Next.js frontend)
NEXT_PUBLIC_API_URL=http://localhost:8000

# Links per page for the dashboard (default: 20)
NEXT_PUBLIC_PER_PAGE=20
